@page
@using tabletennisLib.model
@model TabletennisGUI.Pages.member.IndexModel
@{
}
<h1>Medlems liste</h1>
<div class="row">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Nummer</th>
                <th>Navn</th>
                <th>Mobil</th>
                <th>Fødselsår</th>
            </tr>
        </thead>
        <tbody>
            @foreach(Member m in @Model.Register.ListAll())
            {
                <tr>
                    <td>@m.MemberNo</td>
                    <td>@m.Name</td>
                    <td>@m.Phone</td>
                    <td>@m.YearOfBirth</td>
                </tr>
            }
        </tbody>
    </table>



</div>
